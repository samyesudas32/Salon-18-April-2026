rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * ServiceFlow Hub Security Rules
     *
     * CORE PHILOSOPHY:
     * This ruleset implements a robust Role-Based Access Control (RBAC) system for ServiceFlow Hub.
     * It prioritizes high authorization security while maintaining flexibility for data schemas 
     * during the prototyping phase.
     *
     * DATA STRUCTURE:
     * - User-centric data is stored under /userProfiles/{userId}.
     * - Authorization roles are managed via dedicated marker collections (/adminRoles and /staffRoles).
     * - Operational data (Clients, WorkTypes) are top-level collections accessible by authorized staff.
     * - Transactional data (Bookings) is nested under Clients for efficient historical lookups.
     *
     * KEY SECURITY DECISIONS:
     * 1. Authorization Independence: We use dedicated "Role Collections" (/adminRoles/{uid}) to 
     *    enable fast exists() checks. This avoids expensive get() calls and allows security 
     *    rules to remain atomic.
     * 2. Identity Verification: All access is strictly tied to Firebase Authentication (request.auth).
     * 3. Relational Integrity: Bookings must include a 'clientId' field that matches the path 
     *    to ensure consistency for collectionGroup queries used in dashboards.
     * 4. State Safety: Update and delete operations strictly require the resource to exist 
     *    to prevent orphans or logic errors.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/adminRoles/$(request.auth.uid));
    }

    function isStaff() {
      return isSignedIn() && exists(/databases/$(database)/documents/staffRoles/$(request.auth.uid));
    }

    function isAuthorizedPersonnel() {
      return isAdmin() || isStaff();
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    function isValidRoleUpdate() {
      // Role marker collections are typically managed by backend processes.
      // Prototyping Mode: Restricting write access to prevent self-elevation.
      return false;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for user-specific profile data. Users can manage their own profiles.
     * @path /userProfiles/{userId}
     * @allow (get, update) if the authenticated UID matches the profile UID.
     * @deny (create) if the user attempts to create a profile for a different UID.
     * @principle Restricts access to a user's own data tree and enforces path-to-data consistency.
     */
    match /userProfiles/{userId} {
      allow get: if isOwner(userId);
      allow list: if isAuthorizedPersonnel();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);
    }

    /**
     * @description Marker collection for Administrative roles. Used for fast 'exists()' checks.
     * @path /adminRoles/{userId}
     * @allow (get) for the user themselves or authorized personnel.
     * @deny (write) users cannot elevate their own permissions.
     * @principle Role-Based Access Control via structural segregation.
     */
    match /adminRoles/{userId} {
      allow get: if isOwner(userId) || isAuthorizedPersonnel();
      allow list: if isAuthorizedPersonnel();
      allow create, update, delete: if isValidRoleUpdate();
    }

    /**
     * @description Marker collection for Staff roles. Used for fast 'exists()' checks.
     * @path /staffRoles/{userId}
     * @allow (get) for the user themselves or authorized personnel.
     * @deny (write) users cannot elevate their own permissions.
     * @principle Role-Based Access Control via structural segregation.
     */
    match /staffRoles/{userId} {
      allow get: if isOwner(userId) || isAuthorizedPersonnel();
      allow list: if isAuthorizedPersonnel();
      allow create, update, delete: if isValidRoleUpdate();
    }

    /**
     * @description Management of the client database.
     * @path /clients/{clientId}
     * @allow (read, write) for any user with an Admin or Staff role.
     * @deny (all) for non-authorized personnel or unauthenticated users.
     * @principle Global access for specific roles to a flat collection.
     */
    match /clients/{clientId} {
      allow get, list: if isAuthorizedPersonnel();
      allow create: if isAuthorizedPersonnel();
      allow update, delete: if isAuthorizedPersonnel() && resource != null;

      /**
       * @description Bookings nested under clients. Includes relational validation.
       * @path /clients/{clientId}/bookings/{bookingId}
       * @allow (create) if the 'clientId' in data matches the 'clientId' in the URL path.
       * @deny (read, write) for users who are not Staff or Admins.
       * @principle Path-based structure with denormalized fields for authorization independence.
       */
      match /bookings/{bookingId} {
        allow get, list: if isAuthorizedPersonnel();
        allow create: if isAuthorizedPersonnel() && request.resource.data.clientId == clientId;
        allow update: if isAuthorizedPersonnel() && resource != null && request.resource.data.clientId == resource.data.clientId;
        allow delete: if isAuthorizedPersonnel() && resource != null;
      }
    }

    /**
     * @description Service definition management.
     * @path /workTypes/{workTypeId}
     * @allow (read, write) for any user with an Admin or Staff role.
     * @deny (all) if the user is not authenticated as staff.
     * @principle Homogeneous security posture for configuration data.
     */
    match /workTypes/{workTypeId} {
      allow get, list: if isAuthorizedPersonnel();
      allow create: if isAuthorizedPersonnel();
      allow update, delete: if isAuthorizedPersonnel() && resource != null;
    }

    /**
     * @description Rules for Collection Group queries on 'bookings' across all clients.
     * @path /{path=**}/bookings/{bookingId}
     * @allow (list) for dashboards and reporting if the user is staff/admin.
     * @principle Secures global queries used in administrative views.
     */
    match /{path=**}/bookings/{bookingId} {
      allow list: if isAuthorizedPersonnel();
    }
  }
}

/** 
 * SECURITY NOTE: 
 * The instruction to "add Google Authenticator" refers to an MFA (Multi-Factor Authentication) 
 * configuration within Firebase Authentication. These security rules correctly rely on 
 * 'request.auth', which will automatically reflect the user's verified identity once MFA 
 * is successfully completed at the authentication layer.
 */

/*
Analysis of IR:
1. Adopt Intent: The reasoning specifies Role-Based Access Control using marker collections (adminRoles/staffRoles).
2. Access Patterns:
   - /userProfiles/{userId}: Ownership (isOwner).
   - /adminRoles/{userId} & /staffRoles/{userId}: RBAC Markers.
   - /clients: Staff/Admin shared access.
   - /workTypes: Staff/Admin shared access.
   - /clients/{clientId}/bookings: Staff/Admin shared access with relational validation to clientId.
3. Ambiguities: The prompt mentions Google Authenticator; as the backend reasoning notes, this is an Auth layer concern, not a database schema concern. Rules reflect this by strictly requiring `request.auth`.
*/
/**
 * Core Philosophy: This ruleset enforces a strict user-ownership model. In this "Authorization Independence" 
 * architecture, all application data is silioed under a specific user's root document. This ensures 
 * that security is determined by the path itself, making rules performant and easy to reason about.
 *
 * Data Structure: All data is organized hierarchically under the `/users/{userId}` path. 
 * Specific entities like Clients, WorkTypes, Bookings, and Backups exist as subcollections 
 * of the user who owns them (e.g., `/users/{userId}/bookings/{bookingId}`).
 *
 * Key Security Decisions:
 * 1. Default Posture: All data is private by default. There is no public reading or listing of user data.
 * 2. Path-Based Authorization: The `{userId}` wildcard in the path is compared directly against 
 *    the authenticated user's UID (`request.auth.uid`).
 * 3. Administrative Lockdown: No global admin roles are defined; every user is the sole administrator of 
 *    their own data tree.
 * 4. Relational Integrity: On document creation, the rules enforce that internal 'id' fields match 
 *    the Firestore document ID to ensure consistency between the data and the path.
 *
 * Denormalization for Authorization:
 * Because the data is nested under the user's ID, the path itself provides the necessary context 
 * for authorization. This avoids the need for expensive `get()` calls to look up ownership 
 * on parent or related documents.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /**
     * @description Checks if the request is made by an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the authenticated user's UID matches the provided userId.
     * @param userId The UID of the user who owns the resource.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Combines ownership check with existence check for updates and deletes.
     * @param userId The UID of the user who owns the resource.
     */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /**
     * @description Enforces immutability for critical relational fields.
     */
    function isUnchanged(field) {
      return request.resource.data[field] == resource.data[field];
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the root user document.
     * @path /users/{userId}
     * @allow (get, create, update, delete) if user is the owner.
     * @deny (list) to prevent user enumeration.
     * @principle Self-creation and strict ownership of the profile root.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users cannot be listed/searched.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && isUnchanged('id');
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for clients managed by a specific user.
       * @path /users/{userId}/clients/{clientId}
       * @allow (create) if the user is the owner and provides matching internal ID.
       * @deny (read/write) if request.auth.uid does not match {userId}.
       * @principle Path-based authorization for user-scoped subcollections.
       */
      match /clients/{clientId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.id == clientId;
        allow update: if isExistingOwner(userId) && isUnchanged('id');
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for work type definitions (services) offered by a user.
       * @path /users/{userId}/workTypes/{workTypeId}
       * @allow (list) if the user is the owner of this service list.
       * @deny (update) if the internal 'id' field is being changed.
       * @principle Relational integrity and ownership enforcement.
       */
      match /workTypes/{workTypeId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.id == workTypeId;
        allow update: if isExistingOwner(userId) && isUnchanged('id');
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for service bookings created by the user.
       * @path /users/{userId}/bookings/{bookingId}
       * @allow (create) if the owner is signed in and links the document correctly.
       * @deny (delete) if the booking document does not exist.
       * @principle Strict ownership and existence checks for destructive operations.
       */
      match /bookings/{bookingId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.id == bookingId;
        allow update: if isExistingOwner(userId) && isUnchanged('id');
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for timestamped snapshots of user data.
       * @path /users/{userId}/backups/{backupId}
       * @allow (get) to fetch a specific backup for restoration.
       * @deny (write) for users other than the owner.
       * @principle Ensures backup data remains private and owner-controlled.
       */
      match /backups/{backupId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update: if isExistingOwner(userId);
        allow delete: if isExistingOwner(userId);
      }
    }
  }
}